# Database (optional - defaults work with docker-compose)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bible_memory
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=postgres

# ESV API key - required for verse lookup from ESV API (backend only)
# Obtain at https://api.esv.org/account/create-application/
ESV_API_KEY=your_esv_api_key_here

# CORS allowed origins (comma-separated for dev)
# cors.allowed-origins=http://localhost:4200
